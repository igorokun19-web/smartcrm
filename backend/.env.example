# ==============================================================
# SmartCRM Backend - Environment Variables
# ==============================================================
# 🔒 SECURITY: DO NOT COMMIT .env FILE TO GITHUB!
# This is an example - copy to .env and fill with your values

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Port to run the server on (default: 3001)
PORT=3001

# Environment mode (development, production, test)
NODE_ENV=development

# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:5175

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================

# JWT Secret - GENERATE A STRONG SECRET FOR PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ REQUIRED for production - set on Render dashboard
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================
# EMAIL CONFIGURATION (for password recovery)
# ============================================================

# SMTP Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password  # Use Gmail App Password, not your regular password!
EMAIL_FROM=noreply@myservices.com

# ============================================================
# DATABASE
# ============================================================

# SQLite database location (default: crm.db in current directory)
# Leave empty to use default
DB_PATH=./crm.db

# ============================================================
# SECURITY NOTES
# ============================================================

# 🔐 For Local Development:
# 1. Copy this file to .env
# 2. Fill in development values
# 3. Never commit .env to version control

# 🔐 For Production (Render):
# 1. Generate strong JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Set all variables in Render Dashboard → Settings → Environment Variables
# 3. Use Gmail App Password (not your main password)
# 4. Keep all secrets out of code and version control

# ==============================================================
